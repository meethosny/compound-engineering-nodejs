{
  "name": "@meethosny/js-compound-plugin",
  "version": "2.65.0",
  "description": "Node.js edition of the Compound Engineering plugin for Claude Code, Codex, and more",
  "type": "module",
  "private": true,
  "bin": {
    "js-compound-plugin": "src/index.ts"
  },
  "homepage": "https://github.com/meethosny/compound-engineering-nodejs",
  "repository": "https://github.com/meethosny/compound-engineering-nodejs",
  "scripts": {
    "dev": "bun run src/index.ts",
    "convert": "bun run src/index.ts convert",
    "list": "bun run src/index.ts list",
    "cli:install": "bun run src/index.ts install",
    "test": "bun test tests/",
    "release:preview": "bun run scripts/release/preview.ts",
    "release:sync-metadata": "bun run scripts/release/sync-metadata.ts --write",
    "release:validate": "bun run scripts/release/validate.ts"
  },
  "dependencies": {
    "citty": "^0.1.6",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "bun-types": "^1.0.0",
    "semantic-release": "^25.0.3"
  }
}
